<%- include('header') %>

<div class="card">
    <div class="card-body text-center">
        <h2 class="card-title mb-4">Two-Factor Authentication</h2>
        
        <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <p>Please enter the 6-digit code from your authenticator app.</p>

        <form action="/verify-2fa" method="POST" class="mt-4">
            <div class="mb-3 w-50 mx-auto">
                <input type="text" class="form-control text-center fs-4" name="token" placeholder="000000" required maxlength="6" pattern="\d{6}">
            </div>
            <div class="d-grid gap-2 w-50 mx-auto">
                <button type="submit" class="btn btn-primary">Verify</button>
            </div>
        </form>
        
        <form action="/logout" method="POST" class="mt-4">
            <button type="submit" class="btn btn-link text-danger">Cancel and Logout</button>
        </form>
    </div>
</div>

<%- include('footer') %>
