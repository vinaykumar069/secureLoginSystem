<%- include('header') %>

<div class="card border-success">
    <div class="card-header bg-success text-white">
        Dashboard
    </div>
    <div class="card-body text-center">
        <h3 class="mb-4">Welcome, <%= user.username %>!</h3>
        <p class="text-muted">You have successfully logged in to the secure area.</p>

        <div class="my-4">
            <% if (user.two_factor_enabled) { %>
                <div class="alert alert-info">
                    <strong>Two-Factor Authentication:</strong> Enabled <span class="badge bg-success">Secured</span>
                </div>
            <% } else { %>
                <div class="alert alert-warning">
                    <strong>Two-Factor Authentication:</strong> Disabled
                    <br>
                    <a href="/setup-2fa" class="btn btn-outline-primary btn-sm mt-2">Enable 2FA Now</a>
                </div>
            <% } %>
        </div>

        <form action="/logout" method="POST" class="mt-4">
            <button type="submit" class="btn btn-danger">Logout</button>
        </form>
    </div>
</div>

<%- include('footer') %>
